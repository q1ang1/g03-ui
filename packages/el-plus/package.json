    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "element-plus": "^2.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "element-plus": "catalog:",
    "eslint": "catalog:",
    "sass": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  }
}
