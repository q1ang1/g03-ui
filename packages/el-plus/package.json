{
  "name": "@g03/el-plus",
  "version": "0.1.0",
  "type": "module",
  "description": "Element Plus transparent wrapper with unified g-* class prefix",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles/scss": "./src/styles/index.scss"
  },
